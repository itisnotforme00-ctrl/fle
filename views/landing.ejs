<% var hideLayout = true; %>

<div class="landing-page">
  <!-- Nav -->
  <nav class="landing-nav">
    <a href="/" class="landing-logo">
      <div class="logo-icon">&lt;/&gt;</div>
      DevHunt
    </a>
    <div>
      <a href="/login" style="margin-right: 20px; color: var(--text-secondary);">Sign In</a>
      <a href="/register" class="btn btn-primary">Get Started</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="landing-hero">
    <h1>Stop Begging. <span>Start Landing</span> Industrial Clients.</h1>
    <p>The all-in-one platform for senior developers to hunt high-value clients, generate winning proposals, and manage projects from first contact to final invoice.</p>
    <div class="hero-buttons">
      <a href="/register" class="btn btn-primary">Start Hunting Clients</a>
      <a href="/login" class="btn btn-secondary" style="color: var(--text-primary);">Login</a>
    </div>
  </section>

  <!-- Features -->
  <section class="features-section">
    <h2 class="section-title">Everything You Need to Win Clients</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">&#9733;</div>
        <h3>Lead Radar</h3>
        <p>Track and manage every prospect from first contact to signed contract. Never let a hot lead go cold.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#9998;</div>
        <h3>Proposal Generator</h3>
        <p>Generate professional, formatted proposals in minutes. Hours x Rate = Revenue, beautifully presented.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#9630;</div>
        <h3>Portfolio OS</h3>
        <p>Manage your entire project portfolio with milestones, notes, and invoicing — all in one place.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#9786;</div>
        <h3>Client CRM</h3>
        <p>Organize contacts, track communication history, and nurture relationships that lead to repeat business.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#128;</div>
        <h3>Rate Calculator</h3>
        <p>Know your worth. Calculate optimal rates based on experience, stack, and region with market comparisons.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#9638;</div>
        <h3>Revenue Dashboard</h3>
        <p>See your estimated monthly revenue, active projects, and proposal pipeline at a glance.</p>
      </div>
    </div>
  </section>

  <!-- Roles -->
  <section class="roles-section">
    <h2 class="section-title">Built for Every Type of Developer</h2>
    <div class="roles-grid">
      <div class="role-card">
        <div class="role-icon">&#9680;</div>
        <h3>Backend Engineers</h3>
        <p>API design, database architecture, cloud infrastructure, microservices, DevOps, and system scaling projects.</p>
        <span class="role-tag">Node.js &bull; Go &bull; Python</span>
      </div>
      <div class="role-card">
        <div class="role-icon">&#9681;</div>
        <h3>Frontend Developers</h3>
        <p>React/Vue/Angular apps, design system implementation, performance optimization, and interactive dashboards.</p>
        <span class="role-tag">React &bull; TypeScript &bull; CSS</span>
      </div>
      <div class="role-card">
        <div class="role-icon">&#9681;</div>
        <h3>Fullstack Developers</h3>
        <p>End-to-end product builds, MVP development, technical consulting, and fractional CTO engagements.</p>
        <span class="role-tag">React &bull; Node.js &bull; SQL</span>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how-section">
    <h2 class="section-title">How DevHunt Works</h2>
    <div class="steps-grid">
      <div class="step-card">
        <div class="step-number">1</div>
        <h4>Create Your Profile</h4>
        <p>Set your role, tech stack, and target hourly rate. You're now armed for the hunt.</p>
      </div>
      <div class="step-card">
        <div class="step-number">2</div>
        <h4>Add Client Leads</h4>
        <p>Log every prospect you find — from LinkedIn, GitHub, referrals, and cold outreach.</p>
      </div>
      <div class="step-card">
        <div class="step-number">3</div>
        <h4>Generate Proposals</h4>
        <p>Turn leads into clients with professional proposals that sell value, not hours.</p>
      </div>
      <div class="step-card">
        <div class="step-number">4</div>
        <h4>Track & Invoice</h4>
        <p>Manage milestones, log notes, and generate invoices — all in one streamlined workflow.</p>
      </div>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="footer-cta">
    <h2>Ready to Stop Chasing and Start Landing?</h2>
    <a href="/register" class="btn btn-primary" style="padding: 16px 40px; font-size: 1.1rem;">Create Free Account</a>
    <p style="margin-top: 20px; font-size: 0.85rem; color: var(--text-muted);">
      Demo login: <strong>demo@devhunt.com</strong> / <strong>demo1234</strong>
    </p>
  </section>

  <!-- Footer -->
  <footer style="text-align: center; padding: 30px; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.85rem;">
    &copy; 2026 DevHunt. Built for senior developers who know their worth.
  </footer>
</div>
